# Configuration du backend Sama Impôt
# Copiez ce fichier en « .env » et adaptez les valeurs.

# Clé secrète Django (générez-en une longue et aléatoire en production)
SECRET_KEY=changez-cette-cle-en-production

# Mode debug : True en développement, False en production
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données PostgreSQL (laisser vide pour utiliser SQLite en local)
# Exemple : postgres://utilisateur:motdepasse@hote:5432/nom_base
DATABASE_URL=

# Origines autorisées pour le frontend React
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Origines de confiance pour le CSRF (en production)
CSRF_TRUSTED_ORIGINS=
